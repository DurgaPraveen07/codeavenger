# Vercel Ignore File
# Exclude files that are not needed for the production build on Vercel

node_modules
dist
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.vscode
.idea
*.log
README.md
DEPLOYMENT.md
.gitignore
metadata.json
tsconfig.json
vite.config.ts
postcss.config.js
tailwind.config.js
# Note: vite.config.ts and tailwind.config.js are needed for the build, so we don't ignore them.
# But we can ignore non-essential files.
